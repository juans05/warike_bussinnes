# PostgreSQL — misma DB que WARIKE_BACKEND (wuarike_db), schema separado mesero_digital
# En VPS: DB_HOST=localhost | En local con tunnel: DB_HOST=localhost DB_PORT=5433
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=doadmin
DB_PASSWORD=your_password_here
DB_DATABASE=wuarike_db
DB_SCHEMA=mesero_digital
DB_SSL=false

# JWT — same SECRET as WARIKE_BACKEND (tokens issued by main auth service)
JWT_SECRET=your_jwt_secret_here
JWT_AUDIENCE=warike-business

# Bot Gateway port (WARIKE_BACKEND uses 3001)
BOT_GATEWAY_PORT=3002

# n8n webhook secret (used to authenticate calls from n8n)
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret_here
