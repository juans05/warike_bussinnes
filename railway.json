{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/bot-gateway/Dockerfile"
  },
  "deploy": {
    "startCommand": "node apps/bot-gateway/dist/main",
    "healthcheckPath": "/auth/verify",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
